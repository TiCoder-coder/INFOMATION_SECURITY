# ============================================================
# .env — cấu hình cho ECDH Key Exchange
# (KHÔNG commit file này lên git)
# ============================================================

# ---- Bộ tham số miền (Domain Parameters T) ----
# Tên đường cong elliptic theo chuẩn NIST SP 800-186.
# Bản tự cài hiện hỗ trợ: prime256v1 / secp256r1 / p-256 (cùng một đường cong).
ECDH_CURVE=prime256v1

# ---- Cấu hình KDF (NIST SP 800-56C — HKDF-SHA256) ----
KDF_HASH=sha256
KDF_SALT_HEX=00112233445566778899aabbccddeeff
KDF_INFO=ECDH-AES-Session-Key
KDF_KEY_LENGTH=32

# ---- Cấu hình mã hoá đối xứng ----
SYMMETRIC_ALGORITHM=aes-256-gcm

# ---- Đường dẫn lưu khoá ----
KEY_DIR=./keys
PARTY_A_PRIVATE_KEY_FILE=partyA_private.key
PARTY_A_PUBLIC_KEY_FILE=partyA_public.key
PARTY_B_PRIVATE_KEY_FILE=partyB_private.key
PARTY_B_PUBLIC_KEY_FILE=partyB_public.key
